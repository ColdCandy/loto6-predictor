# このファイルをコピーして secrets.toml にリネームしてください
#   copy secrets.toml.example secrets.toml
#
# Streamlit Cloud の場合:
#   App settings → Secrets に同じ内容を貼り付け
#
# パスワードをハッシュ化する場合:
#   python tools/make_invite_hash.py あなたのパスワード
#   出力された password_hash を使い、password 行は削除

[auth]
enabled = true
app_title = "ロト6予想（招待制）"
max_failures = 8

[[auth.invites]]
username = "family1"
password = "必ず変更してください-1"
label = "家族1"

[[auth.invites]]
username = "family2"
password = "必ず変更してください-2"
label = "家族2"
